pub fn concat(a: String, b: String) -> String {
  a <> b
}

pub fn repeat(s: String, n: Int) -> String {
  if n <= 0 { "" }
  else { s <> repeat(s, n - 1) }
}

pub fn join(sep: String, a: String, b: String) -> String {
  a <> sep <> b
}

fn main() {
  println("concat: " <> concat("hello", " world"))
  println("repeat: " <> repeat("ab", 3))
  println("join: " <> join(", ", "foo", "bar"))
}
