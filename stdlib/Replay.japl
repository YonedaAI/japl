type ReplayEntry = | Entry(Int, String, String)
type ReplayLog = | LogEntry(ReplayEntry, ReplayLog) | LogEmpty

pub fn replay_new() -> ReplayLog {
  LogEmpty
}

pub fn replay_record(log: ReplayLog, step: Int, action: String, result: String) -> ReplayLog {
  let entry = Entry(step, action, result)
  LogEntry(entry, log)
}

pub fn replay_size(log: ReplayLog) -> Int {
  match log {
    LogEmpty => 0,
    LogEntry(_, rest) => 1 + replay_size(rest)
  }
}

pub fn replay_latest(log: ReplayLog) -> Int {
  match log {
    LogEmpty => 0 - 1,
    LogEntry(e, _) => match e { Entry(s, _, _) => s }
  }
}

pub fn replay_llm_call(log: ReplayLog, step: Int, prompt: String) -> ReplayLog {
  replay_record(log, step, "llm_call", prompt)
}

pub fn replay_tool_call(log: ReplayLog, step: Int, tool_name: String) -> ReplayLog {
  replay_record(log, step, "tool_call", tool_name)
}

pub fn replay_spawn(log: ReplayLog, step: Int, pid: String) -> ReplayLog {
  replay_record(log, step, "spawn", pid)
}

pub fn replay_latest_action(log: ReplayLog) -> String {
  match log {
    LogEmpty => "none",
    LogEntry(e, _) => match e { Entry(_, a, _) => a }
  }
}

fn main() {
  let log = replay_new()
  let s0 = replay_size(log)
  println("empty_size: " <> show(s0))
  let lat0 = replay_latest(log)
  println("empty_latest: " <> show(lat0))
  let log = replay_record(log, 1, "call_tool", "ok")
  let log = replay_record(log, 2, "parse", "done")
  let log = replay_record(log, 3, "respond", "sent")
  let s1 = replay_size(log)
  println("size: " <> show(s1))
  let lat1 = replay_latest(log)
  println("latest: " <> show(lat1))
  let log2 = replay_new()
  let log2 = replay_llm_call(log2, 1, "hello")
  let log2 = replay_tool_call(log2, 2, "search")
  let log2 = replay_spawn(log2, 3, "pid_42")
  let s2 = replay_size(log2)
  println("event_size: " <> show(s2))
  let a2 = replay_latest_action(log2)
  println("latest_action: " <> a2)
  let empty_action = replay_latest_action(replay_new())
  println("empty_action: " <> empty_action)
}
