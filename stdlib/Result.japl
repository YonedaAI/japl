type Result =
  | Ok(Int)
  | Err(String)

pub fn map_result(r: Result, f: fn(Int) -> Int) -> Result {
  match r {
    Ok(x) => Ok(f(x))
    Err(e) => Err(e)
  }
}

pub fn unwrap_or_result(r: Result, fallback: Int) -> Int {
  match r {
    Ok(x) => x
    Err(_) => fallback
  }
}

pub fn is_ok(r: Result) -> Bool {
  match r {
    Ok(_) => true
    Err(_) => false
  }
}

pub fn is_err(r: Result) -> Bool {
  match r {
    Ok(_) => false
    Err(_) => true
  }
}
