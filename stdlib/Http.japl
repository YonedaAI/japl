// Http.japl — HTTP server types and helpers for JAPL
//
// STATUS: Partial — types and routing logic defined.
// BLOCKED ON:
//   1. String function parameters (codegen emits i32 instead of i64)
//   2. Record field access (always returns first field)
//   3. String equality comparison
//   4. TCP host functions (tcp_listen, tcp_accept, tcp_read, tcp_write, tcp_close)
//
// Once those are resolved, this module provides a complete HTTP server API.

type Method = | GET | POST | PUT | DELETE

type Request = {
  method: Method,
  path: String,
  body: String,
  headers: String
}

type Response = {
  status: Int,
  body: String,
  content_type: String
}

type Route = {
  method: Method,
  path: String,
  handler: fn(Request) -> Response
}

// --- Method utilities ---

fn method_tag(m: Method) -> Int {
  match m { GET => 0, POST => 1, PUT => 2, DELETE => 3 }
}

fn method_name(m: Method) -> String {
  match m { GET => "GET", POST => "POST", PUT => "PUT", DELETE => "DELETE" }
}

fn method_eq(a: Method, b: Method) -> Int {
  if method_tag(a) == method_tag(b) { 1 } else { 0 }
}

