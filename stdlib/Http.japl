fn main() {
  println("Http.japl — HTTP module loaded")
  println("Method tags: GET=" <> show(method_tag(GET)) <> " POST=" <> show(method_tag(POST)))
  println("Status: " <> status_text(200))
  println("Status: " <> status_text(404))
}
