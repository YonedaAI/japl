// --- Status text helper (works today) ---

fn status_text(code: Int) -> String {
  if code == 200 { "200 OK" }
  else if code == 201 { "201 Created" }
  else if code == 404 { "404 Not Found" }
  else if code == 400 { "400 Bad Request" }
  else if code == 500 { "500 Internal Server Error" }
  else { show(code) }
}

