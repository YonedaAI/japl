type Option =
  | Some(Int)
  | None

pub fn map_option(opt: Option, f: fn(Int) -> Int) -> Option {
  match opt {
    Some(x) => Some(f(x))
    None => None
  }
}

pub fn unwrap_or(opt: Option, fallback: Int) -> Int {
  match opt {
    Some(x) => x
    None => fallback
  }
}

pub fn is_some(opt: Option) -> Bool {
  match opt {
    Some(_) => true
    None => false
  }
}

pub fn is_none(opt: Option) -> Bool {
  match opt {
    Some(_) => false
    None => true
  }
}
