// Json.japl — JSON encoding helpers for JAPL
//
// STATUS: Partial — Int/Bool/null encoding works.
// BLOCKED ON:
//   1. String function parameters (codegen emits i32 instead of i64)
//      — json_string(s) cannot take a String param yet
//   2. show() shared buffer — multiple show() calls in one expression
//      all return the last value. Use incremental concatenation:
//        let s1 = "[" <> show(1)
//        let s2 = s1 <> "," <> show(2)   // correct
//      NOT:
//        let s = "[" <> show(1) <> "," <> show(2)  // both become 2
//
// ENCODING PATTERN:
//   JSON values are encoded as String. Compose with <> to build objects/arrays.
//   All json_* functions return String so they compose naturally.

// --- Primitive encoders ---

fn json_int(n: Int) -> String {
  show(n)
}

fn json_bool(b: Int) -> String {
  if b == 1 { "true" } else { "false" }
}

fn json_null() -> String {
  "null"
}

// --- String encoder (blocked on String params) ---
// Uncomment once String param codegen is fixed:
//
// pub fn json_string(s: String) -> String {
//   "\"" <> s <> "\""
// }

