// pub fn json_object_1(k1: String, v1: String) -> String {
//   "{" <> json_kv(k1, v1) <> "}"
// }
//
// pub fn json_object_2(k1: String, v1: String, k2: String, v2: String) -> String {
//   "{" <> json_kv(k1, v1) <> "," <> json_kv(k2, v2) <> "}"
// }
//
// pub fn json_object_3(k1: String, v1: String, k2: String, v2: String, k3: String, v3: String) -> String {
//   "{" <> json_kv(k1, v1) <> "," <> json_kv(k2, v2) <> "," <> json_kv(k3, v3) <> "}"
// }

// --- Array builders (blocked on String params) ---
//
// pub fn json_array_1(a: String) -> String {
//   "[" <> a <> "]"
// }
//
// pub fn json_array_2(a: String, b: String) -> String {
//   "[" <> a <> "," <> b <> "]"
// }
//
// pub fn json_array_3(a: String, b: String, c: String) -> String {
//   "[" <> a <> "," <> b <> "," <> c <> "]"
// }

fn main() {
  println("Json.japl — JSON module loaded")

  // Demonstrate working encoders
  println("Int:  " <> json_int(42))
  println("Bool: " <> json_bool(1))
  println("Null: " <> json_null())

  // Build a JSON object incrementally (workaround for show buffer)
  let obj1 = "{\"port\":" <> show(8080)
  let obj = obj1 <> ",\"debug\":" <> json_bool(1) <> "}"
  println("Object: " <> obj)
}
