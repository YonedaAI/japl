#!/bin/bash
set -e
JAPL_HOME="$(cd "$(dirname "$0")/.." && pwd)"
COMPILER="$JAPL_HOME/japl-compiler/target/release/japl-compiler"
RUNTIME="$JAPL_HOME/japl-runtime/target/release/japl-runtime"

[ -f "$COMPILER" ] || COMPILER="$JAPL_HOME/japl-compiler/target/debug/japl-compiler"
[ -f "$RUNTIME" ] || RUNTIME="$JAPL_HOME/japl-runtime/target/debug/japl-runtime"

case "$1" in
  build)
    shift
    # Pass all args to the compiler
    "$COMPILER" build "$@"

    # Determine which .japl file was passed and what --out dir was used
    JAPL_FILE=""
    OUT_DIR="build"
    ARGS=("$@")
    for ((i=0; i<${#ARGS[@]}; i++)); do
      case "${ARGS[$i]}" in
        --out) OUT_DIR="${ARGS[$((i+1))]}" ;;
        *.japl) JAPL_FILE="${ARGS[$i]}" ;;
      esac
    done
    [ -z "$JAPL_FILE" ] && exit 0
    BASENAME=$(basename "$JAPL_FILE" .japl)

    # After producing core.wasm, wrap as WASM Component if wasm-tools is available
    ADAPTER="$JAPL_HOME/deploy/adapters/wasi_snapshot_preview1.command.wasm"
    if command -v wasm-tools >/dev/null 2>&1 && [ -f "$ADAPTER" ] && [ -f "$OUT_DIR/$BASENAME.wasm" ]; then
      wasm-tools component new "$OUT_DIR/$BASENAME.wasm" \
        --adapt "wasi_snapshot_preview1=$ADAPTER" \
        -o "$OUT_DIR/${BASENAME}_component.wasm" 2>/dev/null
      if [ $? -eq 0 ]; then
        mv "$OUT_DIR/${BASENAME}_component.wasm" "$OUT_DIR/$BASENAME.wasm"
        echo "  (WASM Component)" >&2
      fi
    fi
    ;;
  check) shift; "$COMPILER" check "$@" ;;
  fmt)   shift; "$COMPILER" fmt "$@" ;;
  run)
    shift
    JAPL_FILE=""
    for arg in "$@"; do [[ "$arg" == *.japl ]] && JAPL_FILE="$arg"; done
    [ -z "$JAPL_FILE" ] && echo "Usage: japl run <file.japl>" && exit 1
    TMPDIR=$(mktemp -d)
    trap "rm -rf $TMPDIR" EXIT
    BASENAME=$(basename "$JAPL_FILE" .japl)
    "$COMPILER" build "$JAPL_FILE" --out "$TMPDIR" 2>/dev/null
    if grep -q "japl" "$TMPDIR/$BASENAME.wasm" 2>/dev/null; then
      "$RUNTIME" run "$TMPDIR/$BASENAME.wasm"
    else
      wasmtime "$TMPDIR/$BASENAME.wasm"
    fi
    ;;
  new)
    shift; NAME="$1"
    [ -z "$NAME" ] && echo "Usage: japl new <name>" && exit 1
    mkdir -p "$NAME/src"
    echo "[package]\nname = \"$NAME\"\nversion = \"0.1.0\"\nentry = \"src/main.japl\"" > "$NAME/japl.toml"
    echo "fn main() {\n  println(\"Hello from $NAME!\")\n}" > "$NAME/src/main.japl"
    echo "Created project $NAME"
    ;;
  deploy)
    shift
    JAPL_FILE="$1"
    [ -z "$JAPL_FILE" ] && echo "Usage: japl deploy <file.japl>" && exit 1

    BASENAME=$(basename "$JAPL_FILE" .japl)

    # Build first
    "$0" build "$JAPL_FILE"

    # Check for wash
    if ! command -v wash >/dev/null 2>&1; then
      echo "wash not installed. Install: brew install wasmcloud/wasmcloud/wash"
      exit 1
    fi

    # Check for wadm manifest next to the source file
    WADM="$(dirname "$JAPL_FILE")/wadm.yaml"
    if [ -f "$WADM" ]; then
      echo "Deploying with wadm manifest: $WADM"
      # wash 0.18+ supports 'wash app deploy', but wash 2.x removed it
      if wash app deploy --help >/dev/null 2>&1; then
        wash app deploy "$WADM"
      else
        WASH_VER=$(wash --version 2>/dev/null || echo "unknown")
        echo "Error: 'wash app deploy' is not available in $WASH_VER."
        echo "wash 2.x removed the 'wash app' subcommand."
        echo "Use instead:"
        echo "  wash dev    — start a local dev server for the component"
        echo "  wadm deploy — if you have wadm CLI installed separately"
        exit 1
      fi
    else
      echo "No wadm.yaml found next to $JAPL_FILE"
      echo "Create one to define deployment topology, or use: wash dev"
    fi
    ;;
  version) echo "japl 1.0.0" ;;
  *) echo "JAPL — japl build|run|check|fmt|new|deploy|version <file.japl>" ;;
esac
