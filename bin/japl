#!/bin/bash
set -e

JAPL_HOME="$(cd "$(dirname "$0")/.." && pwd)"
COMPILER_WASM="$JAPL_HOME/compiler/self/compiler.wasm"
RUNTIME="$JAPL_HOME/japl-runtime/target/release/japl-runtime"

if [ ! -f "$RUNTIME" ]; then
  RUNTIME="$JAPL_HOME/japl-runtime/target/debug/japl-runtime"
fi

case "$1" in
  build)
    shift
    JAPL_FILE="$1"
    if [ -z "$JAPL_FILE" ]; then
      echo "Usage: japl build <file.japl>"
      exit 1
    fi

    BASENAME=$(basename "$JAPL_FILE" .japl)
    OUT_DIR="${2:-build}"
    mkdir -p "$OUT_DIR"

    TMPDIR=$(mktemp -d)
    trap "rm -rf $TMPDIR" EXIT

    # Copy source to where compiler expects it
    cp "$JAPL_FILE" "$TMPDIR/input.japl"

    # Run self-hosted compiler (reads input.japl, outputs WAT to stdout)
    cd "$TMPDIR"
    "$RUNTIME" run "$COMPILER_WASM" 2>/dev/null > "$BASENAME.wat"

    # Compile WAT to WASM
    wat2wasm "$BASENAME.wat" -o "$BASENAME.wasm" 2>/dev/null

    # Move to output
    cd - > /dev/null
    mv "$TMPDIR/$BASENAME.wasm" "$OUT_DIR/$BASENAME.wasm"
    echo "Compiled $JAPL_FILE → $OUT_DIR/$BASENAME.wasm"
    ;;

  run)
    shift
    JAPL_FILE=""
    EXTRA_ARGS=()
    for arg in "$@"; do
      if [[ "$arg" == *.japl ]]; then
        JAPL_FILE="$arg"
      else
        EXTRA_ARGS+=("$arg")
      fi
    done

    if [ -z "$JAPL_FILE" ]; then
      echo "Usage: japl run <file.japl>"
      exit 1
    fi

    TMPDIR=$(mktemp -d)
    trap "rm -rf $TMPDIR" EXIT

    BASENAME=$(basename "$JAPL_FILE" .japl)

    # Copy source
    cp "$JAPL_FILE" "$TMPDIR/input.japl"

    # Compile
    cd "$TMPDIR"
    "$RUNTIME" run "$COMPILER_WASM" 2>/dev/null > "$BASENAME.wat"
    wat2wasm "$BASENAME.wat" -o "$BASENAME.wasm" 2>/dev/null
    cd - > /dev/null

    # Run (use wasmtime for simple, japl-runtime for processes)
    if grep -q "japl" "$TMPDIR/$BASENAME.wasm" 2>/dev/null; then
      "$RUNTIME" run "$TMPDIR/$BASENAME.wasm" "${EXTRA_ARGS[@]}"
    else
      wasmtime "$TMPDIR/$BASENAME.wasm" 2>/dev/null || "$RUNTIME" run "$TMPDIR/$BASENAME.wasm"
    fi
    ;;

  version) echo "japl 0.3.0 (self-hosted)" ;;

  help|--help|-h)
    echo "JAPL 0.3.0 — Just Another Programming Language"
    echo "Compiler: 1557 lines of JAPL, 21KB WASM. No JavaScript."
    echo ""
    echo "  japl build <file.japl>    Compile to WASM"
    echo "  japl run <file.japl>      Compile and execute"
    echo "  japl version              Version"
    echo "  japl help                 Help"
    ;;

  *) echo "Unknown: $1. Try: japl help" && exit 1 ;;
esac
