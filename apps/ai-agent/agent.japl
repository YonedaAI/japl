type Msg =
  | Ask(Int)
  | Reply(Int)

fn agent_loop() {
  receive {
    Ask(n) =>
      println("agent got: " <> show(n))
      agent_loop()
  }
}

fn main() {
  println("=== JAPL AI Agent ===")
  let agent = spawn(fn() { agent_loop() })
  send(agent, Ask(42))
  send(agent, Ask(99))
  println("=== Done ===")
}
