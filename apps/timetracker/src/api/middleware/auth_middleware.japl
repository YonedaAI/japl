// Middleware: JWT authentication

fn with_auth(handler) {
  fn(req) {
    if string_length(req.user_id) > 0 {
      handler(req)
    } else {
      unauthorized()
    }
  }
}

fn extract_token(authorization) {
  if string_length(authorization) > 7 {
    Some(authorization)
  } else {
    None
  }
}
