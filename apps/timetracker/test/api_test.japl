// API integration tests

type Method =
  | GET
  | POST
  | PUT
  | DELETE

fn ok(body) { { status: 200, body: body } }
fn created(body) { { status: 201, body: body } }
fn bad_request(msg) { { status: 400, body: msg } }
fn unauthorized() { { status: 401, body: "Unauthorized" } }
fn not_found() { { status: 404, body: "Not Found" } }
fn server_error(msg) { { status: 500, body: msg } }

fn method_to_string(m) {
  match m {
    GET => "GET",
    POST => "POST",
    PUT => "PUT",
    DELETE => "DELETE"
  }
}

fn method_eq(a, b) {
  method_to_string(a) == method_to_string(b)
}

fn match_route(routes, req) {
  match routes {
    [] => { status: 404, body: "Not Found" },
    [r, ..rest] =>
      if r.path == req.path {
        if method_eq(r.method, req.method) {
          r.handler(req)
        } else {
          match_route(rest, req)
        }
      } else {
        match_route(rest, req)
      }
  }
}

// -- Tests --

test "route matching finds correct handler" {
  let routes = [{ path: "/test", method: GET, handler: fn(r) { ok("found") } }]
  let req = { method: GET, path: "/test", body: "", user_id: "" }
  let resp = match_route(routes, req)
  resp.status == 200
}

test "route not found returns 404" {
  let routes = [{ path: "/test", method: GET, handler: fn(r) { ok("found") } }]
  let req = { method: GET, path: "/other", body: "", user_id: "" }
  let resp = match_route(routes, req)
  resp.status == 404
}

test "method mismatch returns 404" {
  let routes = [{ path: "/test", method: GET, handler: fn(r) { ok("found") } }]
  let req = { method: POST, path: "/test", body: "", user_id: "" }
  let resp = match_route(routes, req)
  resp.status == 404
}

test "empty routes returns 404" {
  let req = { method: GET, path: "/anything", body: "", user_id: "" }
  let resp = match_route([], req)
  resp.status == 404
}

test "ok helper returns 200" {
  let resp = ok("success")
  resp.status == 200
}

test "created helper returns 201" {
  let resp = created("new resource")
  resp.status == 201
}

test "bad_request helper returns 400" {
  let resp = bad_request("oops")
  resp.status == 400
}

test "unauthorized helper returns 401" {
  let resp = unauthorized()
  resp.status == 401
}

test "not_found helper returns 404" {
  let resp = not_found()
  resp.status == 404
}

test "server_error helper returns 500" {
  let resp = server_error("boom")
  resp.status == 500
}

test "method_to_string GET" {
  method_to_string(GET) == "GET"
}

test "method_to_string POST" {
  method_to_string(POST) == "POST"
}

test "method_eq same methods" {
  method_eq(GET, GET) == true
}

test "method_eq different methods" {
  method_eq(GET, POST) == false
}

test "multiple routes selects correct match" {
  let routes = [
    { path: "/first", method: GET, handler: fn(r) { ok("first") } },
    { path: "/second", method: GET, handler: fn(r) { ok("second") } }
  ]
  let req = { method: GET, path: "/second", body: "", user_id: "" }
  let resp = match_route(routes, req)
  resp.body == "second"
}
