// Domain unit tests

type TimerState =
  | Running(String, String, String)
  | Stopped

type Role =
  | Owner
  | Admin
  | Member

// -- Re-declare functions under test for standalone compilation --

fn validate_email(email) {
  if contains(email, "@") { Ok(email) }
  else { Err("Invalid email format") }
}

fn validate_name(name) {
  if string_length(name) > 0 { Ok(name) }
  else { Err("Name cannot be empty") }
}

fn validate_create_request(req) {
  match validate_email(req.email) {
    Err(e) => Err(e),
    Ok(_) => match validate_name(req.name) {
      Err(e) => Err(e),
      Ok(_) => Ok(req)
    }
  }
}

fn start_timer(user_id, project_id, now_ts) {
  Running(user_id, project_id, now_ts)
}

fn stop_timer(state, now_ts, duration) {
  match state {
    Running(uid, pid, started) => Ok({
      id: "entry-1",
      user_id: uid,
      project_id: pid,
      description: "",
      started_at: started,
      stopped_at: now_ts,
      duration_seconds: duration
    }),
    Stopped => Err("No timer running")
  }
}

fn is_running(state) {
  match state {
    Running(_, _, _) => true,
    Stopped => false
  }
}

fn format_duration(seconds) {
  let hours = seconds / 3600
  let minutes = (seconds - hours * 3600) / 60
  let secs = seconds - hours * 3600 - minutes * 60
  show(hours) <> "h " <> show(minutes) <> "m " <> show(secs) <> "s"
}

fn validate_project_name(name) {
  if string_length(name) > 0 { Ok(name) }
  else { Err("Project name cannot be empty") }
}

fn can_manage(role) {
  match role {
    Owner => true,
    Admin => true,
    Member => false
  }
}

fn role_to_string(role) {
  match role {
    Owner => "owner",
    Admin => "admin",
    Member => "member"
  }
}

fn is_ok(r) {
  match r {
    Ok(_) => true,
    Err(_) => false
  }
}

fn is_err(r) {
  match r {
    Ok(_) => false,
    Err(_) => true
  }
}

// -- Tests --

test "validate valid email" {
  validate_email("alice@test.com") == Ok("alice@test.com")
}

test "validate invalid email" {
  is_err(validate_email("invalid"))
}

test "validate empty name fails" {
  validate_name("") == Err("Name cannot be empty")
}

test "validate non-empty name succeeds" {
  is_ok(validate_name("Alice"))
}

test "validate create request with valid data" {
  let req = { email: "alice@test.com", name: "Alice", password: "secret" }
  is_ok(validate_create_request(req))
}

test "validate create request with invalid email" {
  let req = { email: "invalid", name: "Alice", password: "secret" }
  validate_create_request(req) == Err("Invalid email format")
}

test "start and stop timer" {
  let state = start_timer("user-1", "proj-1", "2024-01-01T00:00:00Z")
  is_running(state)
}

test "stop running timer succeeds" {
  let state = start_timer("user-1", "proj-1", "2024-01-01T00:00:00Z")
  is_ok(stop_timer(state, "2024-01-01T01:00:00Z", 3600))
}

test "stop timer when not running fails" {
  is_err(stop_timer(Stopped, "now", 0))
}

test "timer is not running after Stopped" {
  is_running(Stopped) == false
}

test "format duration hours minutes seconds" {
  format_duration(3661) == "1h 1m 1s"
}

test "format duration zero" {
  format_duration(0) == "0h 0m 0s"
}

test "format duration exact hours" {
  format_duration(7200) == "2h 0m 0s"
}

test "project validation rejects empty name" {
  is_err(validate_project_name(""))
}

test "project validation accepts non-empty name" {
  is_ok(validate_project_name("My Project"))
}

test "owner can manage" {
  can_manage(Owner) == true
}

test "admin can manage" {
  can_manage(Admin) == true
}

test "member cannot manage" {
  can_manage(Member) == false
}

test "role to string owner" {
  role_to_string(Owner) == "owner"
}

test "role to string admin" {
  role_to_string(Admin) == "admin"
}

test "role to string member" {
  role_to_string(Member) == "member"
}
