type Msg =
  | Ping(Int, Pid)
  | Pong(Int)

fn worker() {
  receive {
    Ping(n, reply) =>
      let _ = send(reply, Pong(n))
      worker()
  }
}

fn main() {
  let pid = spawn(fn() { worker() })
  let _ = send(pid, Ping(42, self()))
  let _ = receive {
    Pong(v) => println("got pong: " <> show(v))
  }
  println("parent done")
}
