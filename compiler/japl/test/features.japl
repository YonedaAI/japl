type Option =
  | Some(a)
  | None

fn unwrap_or(opt: Option, fallback: Int) -> Int {
  match opt {
    Some(x) => x
    None => fallback
  }
}

fn double(x: Int) -> Int {
  x * 2
}

fn greet(name: String) -> String {
  "Hello, " <> name <> "!"
}

fn abs(x: Int) -> Int {
  if x > 0 { x }
  else { 0 - x }
}

fn main() {
  let result = unwrap_or(Some(21), 0)
  let doubled = double(result)
  println(show(doubled))
  println(greet("World"))
  println(show(abs(0 - 5)))
}
