type Shape =
  | Circle(Float)
  | Rectangle(Float, Float)

fn area(shape: Shape) -> Float = match shape with
  | Circle(r) -> 3.14159 * r * r
  | Rectangle(w, h) -> w * h

fn main() =
  let c = Circle(5.0)
  let r = Rectangle(3.0, 4.0)
  println("Circle area: " ++ show(area(c)))
  println("Rectangle area: " ++ show(area(r)))
