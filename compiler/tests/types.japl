-- types.japl: Type declarations and pattern matching

type Option[a] =
  | Some(a)
  | None

type Shape =
  | Circle(Float)
  | Rectangle(Float, Float)
  | Triangle(Float, Float, Float)

type Color = { r: Int, g: Int, b: Int }

fn area(shape: Shape) -> Float = match shape with
  | Circle(radius) -> 3.14159 * radius * radius
  | Rectangle(w, h) -> w * h
  | Triangle(a, b, c) ->
    let s = (a + b + c) / 2.0
    s

fn unwrap_or(opt: Option[a], default: a) -> a = match opt with
  | Some(x) -> x
  | None -> default

fn is_bright(c: Color) -> Bool =
  if c.r > 200 then True
  else if c.g > 200 then True
  else False
