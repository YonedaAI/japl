// Self-hosted JAPL compiler — Lexer test
// Tokenizes a JAPL source string and prints the tokens.

foreign "japl" fn char_at(s: Int, idx: Int) -> Int
foreign "japl" fn substring(s: Int, start: Int, end: Int) -> Int
foreign "japl" fn str_length(s: Int) -> Int
foreign "japl" fn string_eq(a: Int, b: Int) -> Int
foreign "japl" fn from_char_code(code: Int) -> Int

// ─── Token types ───

type Token =
  | TkInt(Int)
  | TkString(Int)
  | TkIdent(Int)
  | TkUpperIdent(Int)
  | TkFn
  | TkLet
  | TkType
  | TkMatch
  | TkIf
  | TkElse
  | TkPub
  | TkForeign
  | TkTrue
  | TkFalse
  | TkPlus
  | TkMinus
  | TkStar
  | TkSlash
  | TkEq
  | TkNotEq
  | TkLt
  | TkGt
  | TkLtEq
  | TkGtEq
  | TkLParen
  | TkRParen
  | TkLBrace
  | TkRBrace
  | TkComma
  | TkColon
  | TkArrow
  | TkFatArrow
  | TkConcat
  | TkBar
  | TkDot
  | TkAssign
  | TkEof

type TokenList = | Cons(Token, TokenList) | Nil

// ─── Character classification ───

fn is_digit(c: Int) -> Int {
  if c >= 48 {
    if c <= 57 { 1 } else { 0 }
  } else { 0 }
}

fn is_alpha(c: Int) -> Int {
  if c >= 65 {
    if c <= 90 { 1 }
    else if c >= 97 {
      if c <= 122 { 1 } else { if c == 95 { 1 } else { 0 } }
    }
    else { if c == 95 { 1 } else { 0 } }
  } else { if c == 95 { 1 } else { 0 } }
}

fn is_upper(c: Int) -> Int {
  if c >= 65 { if c <= 90 { 1 } else { 0 } } else { 0 }
}

fn is_alnum(c: Int) -> Int {
  if is_alpha(c) == 1 { 1 }
  else { if is_digit(c) == 1 { 1 } else { 0 } }
}

fn is_whitespace(c: Int) -> Int {
  if c == 32 { 1 }
  else if c == 10 { 1 }
  else if c == 13 { 1 }
  else if c == 9 { 1 }
  else { 0 }
}

// ─── Tokenizer helpers ───

fn find_char(source: Int, pos: Int, len: Int, target: Int) -> Int {
  if pos >= len { len }
  else if char_at(source, pos) == target { pos }
  else { find_char(source, pos + 1, len, target) }
}

fn find_non_digit(source: Int, pos: Int, len: Int) -> Int {
  if pos >= len { len }
  else if is_digit(char_at(source, pos)) == 1 { find_non_digit(source, pos + 1, len) }
  else { pos }
}

fn find_non_alnum(source: Int, pos: Int, len: Int) -> Int {
  if pos >= len { len }
  else if is_alnum(char_at(source, pos)) == 1 { find_non_alnum(source, pos + 1, len) }
  else { pos }
}

fn skip_line_comment(source: Int, pos: Int, len: Int) -> TokenList {
  if pos >= len { Cons(TkEof, Nil) }
  else if char_at(source, pos) == 10 {
    let rest = tokenize_at(source, pos + 1, len)
    rest
  }
  else { skip_line_comment(source, pos + 1, len) }
}

// ─── Keyword recognition ───

fn keyword_or_ident(word: Int) -> Token {
  if string_eq(word, "fn") == 1 { TkFn }
  else if string_eq(word, "let") == 1 { TkLet }
  else if string_eq(word, "type") == 1 { TkType }
  else if string_eq(word, "match") == 1 { TkMatch }
  else if string_eq(word, "if") == 1 { TkIf }
  else if string_eq(word, "else") == 1 { TkElse }
  else if string_eq(word, "pub") == 1 { TkPub }
  else if string_eq(word, "foreign") == 1 { TkForeign }
  else if string_eq(word, "true") == 1 { TkTrue }
  else if string_eq(word, "false") == 1 { TkFalse }
  else {
    if is_upper(char_at(word, 0)) == 1 { TkUpperIdent(word) }
    else { TkIdent(word) }
  }
}

// ─── Read compound tokens ───

fn read_string(source: Int, pos: Int, len: Int) -> TokenList {
  let end = find_char(source, pos, len, 34)
  let str_val = substring(source, pos, end)
  Cons(TkString(str_val), tokenize_at(source, end + 1, len))
}

fn read_number(source: Int, pos: Int, len: Int) -> TokenList {
  let end = find_non_digit(source, pos, len)
  let num_str = substring(source, pos, end)
  Cons(TkInt(num_str), tokenize_at(source, end, len))
}

fn read_ident(source: Int, pos: Int, len: Int) -> TokenList {
  let end = find_non_alnum(source, pos, len)
  let word = substring(source, pos, end)
  let tok = keyword_or_ident(word)
  Cons(tok, tokenize_at(source, end, len))
}

// ─── Main tokenizer ───
// Note: tail-recursive calls that just skip (whitespace, comments)
// are wrapped in let to avoid a TS compiler tail-call optimization bug.

fn tokenize(source: Int) -> TokenList {
  tokenize_at(source, 0, str_length(source))
}

fn tokenize_at(source: Int, pos: Int, len: Int) -> TokenList {
  if pos >= len { Cons(TkEof, Nil) }
  else {
    let c = char_at(source, pos)
    if is_whitespace(c) == 1 {
      let rest = tokenize_at(source, pos + 1, len)
      rest
    }
    else if c == 40 { Cons(TkLParen, tokenize_at(source, pos + 1, len)) }
    else if c == 41 { Cons(TkRParen, tokenize_at(source, pos + 1, len)) }
    else if c == 123 { Cons(TkLBrace, tokenize_at(source, pos + 1, len)) }
    else if c == 125 { Cons(TkRBrace, tokenize_at(source, pos + 1, len)) }
    else if c == 44 { Cons(TkComma, tokenize_at(source, pos + 1, len)) }
    else if c == 58 { Cons(TkColon, tokenize_at(source, pos + 1, len)) }
    else if c == 46 { Cons(TkDot, tokenize_at(source, pos + 1, len)) }
    else if c == 43 { Cons(TkPlus, tokenize_at(source, pos + 1, len)) }
    else if c == 42 { Cons(TkStar, tokenize_at(source, pos + 1, len)) }
    else if c == 47 {
      // / or //comment
      if pos + 1 < len {
        if char_at(source, pos + 1) == 47 { skip_line_comment(source, pos + 2, len) }
        else { Cons(TkSlash, tokenize_at(source, pos + 1, len)) }
      } else { Cons(TkSlash, tokenize_at(source, pos + 1, len)) }
    }
    else if c == 45 {
      // - or ->
      if pos + 1 < len {
        if char_at(source, pos + 1) == 62 { Cons(TkArrow, tokenize_at(source, pos + 2, len)) }
        else { Cons(TkMinus, tokenize_at(source, pos + 1, len)) }
      } else { Cons(TkMinus, tokenize_at(source, pos + 1, len)) }
    }
    else if c == 61 {
      // = or == or =>
      if pos + 1 < len {
        if char_at(source, pos + 1) == 62 { Cons(TkFatArrow, tokenize_at(source, pos + 2, len)) }
        else if char_at(source, pos + 1) == 61 { Cons(TkEq, tokenize_at(source, pos + 2, len)) }
        else { Cons(TkAssign, tokenize_at(source, pos + 1, len)) }
      } else { Cons(TkAssign, tokenize_at(source, pos + 1, len)) }
    }
    else if c == 60 {
      // < or <= or <>
      if pos + 1 < len {
        if char_at(source, pos + 1) == 62 { Cons(TkConcat, tokenize_at(source, pos + 2, len)) }
        else if char_at(source, pos + 1) == 61 { Cons(TkLtEq, tokenize_at(source, pos + 2, len)) }
        else { Cons(TkLt, tokenize_at(source, pos + 1, len)) }
      } else { Cons(TkLt, tokenize_at(source, pos + 1, len)) }
    }
    else if c == 62 {
      // > or >=
      if pos + 1 < len {
        if char_at(source, pos + 1) == 61 { Cons(TkGtEq, tokenize_at(source, pos + 2, len)) }
        else { Cons(TkGt, tokenize_at(source, pos + 1, len)) }
      } else { Cons(TkGt, tokenize_at(source, pos + 1, len)) }
    }
    else if c == 124 { Cons(TkBar, tokenize_at(source, pos + 1, len)) }
    else if c == 33 {
      // ! or !=
      if pos + 1 < len {
        if char_at(source, pos + 1) == 61 { Cons(TkNotEq, tokenize_at(source, pos + 2, len)) }
        else {
          let rest = tokenize_at(source, pos + 1, len)
          rest
        }
      } else {
        let rest = tokenize_at(source, pos + 1, len)
        rest
      }
    }
    else if c == 34 { read_string(source, pos + 1, len) }
    else if is_digit(c) == 1 { read_number(source, pos, len) }
    else if is_alpha(c) == 1 { read_ident(source, pos, len) }
    else {
      let rest = tokenize_at(source, pos + 1, len)
      rest
    }
  }
}

// ─── Token printer ───

fn token_name(t: Token) -> String {
  match t {
    TkFn => "FN",
    TkLet => "LET",
    TkType => "TYPE",
    TkMatch => "MATCH",
    TkIf => "IF",
    TkElse => "ELSE",
    TkPub => "PUB",
    TkForeign => "FOREIGN",
    TkTrue => "TRUE",
    TkFalse => "FALSE",
    TkIdent(s) => "IDENT:" <> s,
    TkUpperIdent(s) => "UPPER:" <> s,
    TkInt(s) => "INT:" <> s,
    TkString(s) => "STRING:" <> s,
    TkPlus => "PLUS",
    TkMinus => "MINUS",
    TkStar => "STAR",
    TkSlash => "SLASH",
    TkEq => "EQ",
    TkNotEq => "NEQ",
    TkLt => "LT",
    TkGt => "GT",
    TkLtEq => "LTEQ",
    TkGtEq => "GTEQ",
    TkLParen => "LPAREN",
    TkRParen => "RPAREN",
    TkLBrace => "LBRACE",
    TkRBrace => "RBRACE",
    TkComma => "COMMA",
    TkColon => "COLON",
    TkArrow => "ARROW",
    TkFatArrow => "FATARROW",
    TkConcat => "CONCAT",
    TkBar => "BAR",
    TkDot => "DOT",
    TkAssign => "ASSIGN",
    TkEof => "EOF"
  }
}

fn print_tokens(tokens: TokenList) -> Int {
  match tokens {
    Nil => 0,
    Cons(tok, rest) => {
      println(token_name(tok))
      print_tokens(rest)
    }
  }
}

fn main() {
  let source = "fn main() { println(42) }"
  let tokens = tokenize(source)
  print_tokens(tokens)
}
